import requests
import os

# 환경 변수에 등록된 키 사용
API_KEY = os.environ.get("GEMINI_API_KEY")
url = f"https://generativelanguage.googleapis.com/v1beta/models?key={API_KEY}"

response = requests.get(url)
models = response.json()

print("--- 사용 가능한 모델 리스트 ---")
if 'models' in models:
    for m in models['models']:
        # 호출 시 사용할 이름 (예: models/gemini-1.5-flash)
        print(f"Name: {m['name']} | Display Name: {m['displayName']}")
else:
    print("모델 리스트를 가져오지 못했습니다. 에러 확인:")
    print(models)
